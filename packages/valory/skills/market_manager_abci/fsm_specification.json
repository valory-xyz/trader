        "FETCH_ERROR",
        "NONE",
        "NO_MAJORITY",
        "POLYMARKET_FETCH_MARKETS",
        "ROUND_TIMEOUT"
    ],
    "transition_func": {
        "(FetchMarketsRouterRound, DONE)": "UpdateBetsRound",
        "(FetchMarketsRouterRound, NONE)": "FetchMarketsRouterRound",
        "(FetchMarketsRouterRound, NO_MAJORITY)": "FetchMarketsRouterRound",
        "(FetchMarketsRouterRound, POLYMARKET_FETCH_MARKETS)": "PolymarketFetchMarketRound",
        "(PolymarketFetchMarketRound, DONE)": "FinishedPolymarketFetchMarketRound",
        "(PolymarketFetchMarketRound, FETCH_ERROR)": "FailedMarketManagerRound",
        "(PolymarketFetchMarketRound, NO_MAJORITY)": "PolymarketFetchMarketRound",
        "(PolymarketFetchMarketRound, ROUND_TIMEOUT)": "PolymarketFetchMarketRound",
        "(UpdateBetsRound, DONE)": "FinishedMarketManagerRound",
        "(UpdateBetsRound, FETCH_ERROR)": "FailedMarketManagerRound",
        "(UpdateBetsRound, NO_MAJORITY)": "UpdateBetsRound",
        "(UpdateBetsRound, ROUND_TIMEOUT)": "UpdateBetsRound"
    }
