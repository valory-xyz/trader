[run]
branch = True
source =
    packages/valory/skills/market_manager_abci
    packages/valory/skills/decision_maker_abci
    packages/valory/skills/trader_abci
    packages/valory/skills/tx_settlement_multiplexer_abci
    packages/valory/skills/staking_abci
    packages/valory/skills/agent_performance_summary_abci
    packages/valory/skills/check_stop_trading_abci
    packages/valory/skills/chatui_abci
    packages/valory/connections/polymarket_client
    packages/valory/customs/bet_amount_per_threshold
    packages/valory/customs/kelly_criterion_no_conf
    packages/valory/customs/mike_strat
omit =
    */tests/*
    */__init__.py
    */*_pb2.py

[report]
fail_under = 100
show_missing = True
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if TYPE_CHECKING:
    pass
partial_branches =
    pragma: no branch
